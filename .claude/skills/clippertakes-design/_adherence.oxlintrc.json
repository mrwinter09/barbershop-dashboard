{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/forms/**",
              "components/story/**",
              "ui_kits/site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Newsreader|Hanken Grotesk|Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Newsreader, Hanken Grotesk, Space Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|tone|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md|lg)$/]",
        "message": "<Avatar> size must be one of 'xs' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|petrol|clay|moss)$/]",
        "message": "<Avatar> tone must be one of 'neutral' | 'petrol' | 'clay' | 'moss'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|fullWidth|leftIcon|rightIcon|as|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, fullWidth, leftIcon, rightIcon, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:withBorder|shadow|padding|hoverable|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: withBorder, shadow, padding, hoverable, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='shadow'] > Literal[value!=/^(?:none|sm|md)$/]",
        "message": "<Card> shadow must be one of 'none' | 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> padding must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NeighborhoodTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|count|active|as|key|ref|className|style|children)$/]",
        "message": "<NeighborhoodTag> doesn't accept that prop. Declared props: name, count, active, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='NeighborhoodTag'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a|span)$/]",
        "message": "<NeighborhoodTag> as must be one of 'button' | 'a' | 'span'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressCounter'] > JSXAttribute > JSXIdentifier[name!=/^(?:count|total|label|size|onDark|key|ref|className|style|children)$/]",
        "message": "<ProgressCounter> doesn't accept that prop. Declared props: count, total, label, size, onDark."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressCounter'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md)$/]",
        "message": "<ProgressCounter> size must be one of 'lg' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReflectionForm'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|hint|onSubmit|key|ref|className|style|children)$/]",
        "message": "<ReflectionForm> doesn't accept that prop. Declared props: title, hint, onSubmit."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReflectionItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|name|neighborhood|date|key|ref|className|style|children)$/]",
        "message": "<ReflectionItem> doesn't accept that prop. Declared props: text, name, neighborhood, date."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StoryCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|total|name|role|neighborhood|image|teaser|status|statusTag|as|children|key|ref|className|style|children)$/]",
        "message": "<StoryCard> doesn't accept that prop. Declared props: number, total, name, role, neighborhood, image, teaser, status, statusTag, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StoryCard'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:a|button|div)$/]",
        "message": "<StoryCard> as must be one of 'a' | 'button' | 'div'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StoryStatusTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|label|key|ref|className|style|children)$/]",
        "message": "<StoryStatusTag> doesn't accept that prop. Declared props: status, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|onChange|disabled|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: label, checked, onChange, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|error|hint|required|multiline|rows|key|ref|className|style|children)$/]",
        "message": "<TextInput> doesn't accept that prop. Declared props: label, error, hint, required, multiline, rows."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
